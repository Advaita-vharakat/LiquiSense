<!DOCTYPE html>
<html>
<head>
<title>LiquiSense Dashboard</title>

<link rel="stylesheet" href="/css/style.css">
<link rel="stylesheet" href="/css/dashboard.css">

</head>

<body>

<div class="container">

<%- include("partials/sidebar") %>

<div class="content">
<div class="content">

<!-- TOPBAR -->
<div class="topbar">
	<div class="search">
		<svg width="18" height="18" viewBox="0 0 24 24" fill="none" style="opacity:.7;margin-right:8px"><path d="M21 21l-4.35-4.35" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/><path d="M11 19a8 8 0 100-16 8 8 0 000 16z" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
		<input type="search" placeholder="Search devices, reports...">
	</div>

	<div class="actions-bar">
		<a class="icon-btn" href="/settings">Profile</a>
	</div>
</div>
<!-- HERO SECTION -->
<div class="hero-section">

<canvas id="leafCanvas"></canvas>

<div class="hero-content">

<div class="hero-badge">AGRITHON 2.0</div>

<h1 class="hero-title">
LiquiSense Monitoring Dashboard
</h1>

<p class="hero-subtitle">
Embedded Food Adulteration Screening System
</p>

</div>

</div>


<!-- QUICK STATS -->
<div class="stats">

<div class="stat-card">
<h2>12</h2>
<p>Tests Today</p>
</div>

<div class="stat-card">
<h2>25+</h2>
<p>Devices Connected</p>
</div>

<div class="stat-card">
<h2>50+</h2>
<p>Total Screenings</p>
</div>

</div>


<!-- QUICK ACTIONS -->
<div class="actions">

<a href="/fssai" class="action green">
<h3>FSSAI Guidelines</h3>
<p>Food safety references</p>
</a>

<a href="/schemes" class="action orange">
<h3>Gov Schemes</h3>
<p>Agriculture initiatives</p>
</a>

</div>


<!-- UPCOMING EVENTS (moved below actions) -->
<h2 class="section-title">Upcoming Events</h2>
<div class="cards full-bleed">
	<div class="card event-card">
		<div class="event-row">
			<img src="/images/workshop.png" alt="Workshop" class="event-img">
			<div class="event-body">
				<h3>Milk Adulteration Workshop</h3>
				<p class="muted">Interactive session with farmers</p>
				<div class="event-footer">
					<div class="event-deadline">Deadline: <strong>2026-03-05</strong></div>
					<button class="register-btn" data-event="workshop">Register</button>
				</div>
			</div>
		</div>
	</div>

	<div class="card event-card">
		<div class="event-row">
			<img src="/images/screening.png" alt="Drive" class="event-img">
			<div class="event-body">
				<h3>Screening Drive - Village A</h3>
				<p class="muted">On-field rapid testing camp</p>
				<div class="event-footer">
					<div class="event-deadline">Date: <strong>2026-02-25</strong></div>
					<button class="register-btn" data-event="drive">Register</button>
				</div>
			</div>
		</div>
	</div>

	<div class="card event-card">
		<div class="event-row">
			<img src="/images/reports.png" alt="Report" class="event-img">
			<div class="event-body">
				<h3>Report Submission</h3>
				<p class="muted">Finalize quarterly screening report</p>
				<div class="event-footer">
					<div class="event-deadline">Deadline: <strong>2026-03-10</strong></div>
					<button class="register-btn" data-event="report">Register</button>
				</div>
			</div>
		</div>
	</div>
</div>


<!-- SENSOR SECTION -->
<div class="card">
Connection
<h3 id="connection">Connected</h3>
</div>

<div class="card">
Time
<h3 id="liveClock"></h3>
</div>

</div>

</div>
</div>

<script src="/js/main.js"></script>
<script src="/js/dashboard.js"></script>

</body>
</html>
