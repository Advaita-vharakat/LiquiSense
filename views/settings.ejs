<!DOCTYPE html>
<html>
<head>
	<title>LiquiSense - Settings</title>
	<link rel="stylesheet" href="/css/style.css">
	<link rel="stylesheet" href="/css/settings.css">
	<link rel="stylesheet" href="/css/dashboard.css">
</head>
<body>

	<div class="container">

		<%- include("partials/sidebar") %>

		<div class="content">

			<div class="topbar">
				<div>
					<h1>Settings</h1>
					<p class="sub">Configure device and app preferences</p>
				</div>
				<div class="actions-bar">
					<button id="themeToggle" class="theme-toggle">Theme</button>
				</div>
			</div>

			<div class="settings-grid">

				<section class="panel">
					<h3>Device Information</h3>
					<div class="list">
						<div class="list-item">
							<div class="item-left"><div class="icon">
								<svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="3"/><path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 1 1-2.83 2.83l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V20a2 2 0 1 1-4 0v-.09a1.65 1.65 0 0 0-1-1.51 1.65 1.65 0 0 0-1.82.33l-.06.06A2 2 0 1 1 2.27 16.8l.06-.06a1.65 1.65 0 0 0 .33-1.82 1.65 1.65 0 0 0-1.51-1H4a2 2 0 1 1 0-4h.09a1.65 1.65 0 0 0 1.51-1 1.65 1.65 0 0 0-.33-1.82L5.3 2.27A2 2 0 1 1 8.13.44l.06.06a1.65 1.65 0 0 0 1.82.33H11a1.65 1.65 0 0 0 1-.33l.06-.06A2 2 0 1 1 16.8 2.27l-.06.06a1.65 1.65 0 0 0-1.82.33 1.65 1.65 0 0 0-.33 1.82V11a1.65 1.65 0 0 0 1 1.51c.47.18.9.45 1.28.83z"/></svg>
							</div></div>
							<div class="item-body">
								<div class="item-title">ESP32 IP Address</div>
								<div class="item-sub">Device connection address</div>
							</div>
							<div class="item-right"><input class="input" placeholder="e.g., 192.168.4.1"></div>
						</div>

						<div class="list-item">
							<div class="item-left"><div class="icon">
								<svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="16" x2="12" y2="12"/><line x1="12" y1="8" x2="12.01" y2="8"/></svg>
							</div></div>
							<div class="item-body">
								<div class="item-title">Firmware Version</div>
								<div class="item-sub">1.0.2</div>
							</div>
							<div class="item-right">&nbsp;</div>
						</div>

						<div class="list-item">
							<div class="item-left"><div class="icon">
								<svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2l7 4v6c0 5-3.6 9-7 10-3.4-1-7-5-7-10V6l7-4z"/></svg>
							</div></div>
							<div class="item-body">
								<div class="item-title">Last Calibration</div>
								<div class="item-sub">Not available</div>
							</div>
							<div class="item-right">&nbsp;</div>
						</div>
					</div>
				</section>

				<section class="panel">
					<h3>Connection</h3>
					<div class="list">
						<div class="list-item">
							<div class="item-left"><div class="icon">
								<svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M2 12.5C6 8.5 10 6 12 6s6 2.5 10 6.5"/><path d="M7 17a5 5 0 0 1 10 0"/><path d="M12 20.5v.5"/></svg>
							</div></div>
							<div class="item-body">
								<div class="item-title">Wi‑Fi Mode</div>
								<div class="item-sub">Connect via local network</div>
							</div>
							<div class="item-right"><label class="switch"><input id="wifiToggle" type="checkbox"><span class="slider"></span></label></div>
						</div>

						<div class="list-item muted">
							<div class="item-left"><div class="icon">
								<svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2a10 10 0 1 0 0 20"/><path d="M17 7l-5 5-5-5"/></svg>
							</div></div>
							<div class="item-body">
								<div class="item-title">Bluetooth Mode</div>
								<div class="item-sub">Coming soon</div>
							</div>
							<div class="item-right"><label class="switch disabled"><input type="checkbox" disabled><span class="slider"></span></label></div>
						</div>
					</div>
				</section>

				<section class="panel info-panel">
					<h3>Calibration</h3>
					<div class="callout">Calibration Managed by Device — Sensor calibration is performed on the ESP32 firmware. This app does not modify calibration settings.</div>
				</section>

				<section class="panel">
					<h3>Data Management</h3>
					<div class="list">
						<a class="list-item action-link" href="/export">
							<div class="item-left"><div class="icon">
								<svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 5 17 10"/><line x1="12" y1="5" x2="12" y2="17"/></svg>
							</div>
							<div class="item-body">
								<div class="item-title">Export Data</div>
								<div class="item-sub">Download test history as CSV</div>
							</div>
							<div class="item-right"><svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg></div>
						</a>

						<a class="list-item action-link" href="/report">
							<div class="item-left"><div class="icon">
								<svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
							</div>
							<div class="item-body">
								<div class="item-title">Generate Report</div>
								<div class="item-sub">Create PDF summary report</div>
							</div>
							<div class="item-right"><svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg></div>
						</a>
					</div>
				</section>

				<section class="panel">
					<h3>About</h3>
					<div class="list">
						<div class="list-item">
							<div class="item-left"><div class="icon">
								<svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="16" x2="12" y2="12"/><line x1="12" y1="8" x2="12.01" y2="8"/></svg>
							</div></div>
							<div class="item-body">
								<div class="item-title">App Version</div>
								<div class="item-sub">v1.0.0 (2026.02.001)</div>
							</div>
							<div class="item-right">&gt;</div>
						</div>

						<a class="list-item action-link" href="/disclaimer">
							<div class="item-left"><div class="icon">
								<svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M3 21h18"/><path d="M12 2v20"/><path d="M7 8h10"/></svg>
							</div></div>
							<div class="item-body">
								<div class="item-title">Disclaimer</div>
								<div class="item-sub">Important usage information</div>
							</div>
							<div class="item-right"><svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg></div>
						</a>

						<div class="list-item">
							<div class="item-left"><div class="icon">❓</div></div>
							<div class="item-body">
								<div class="item-title">Help & Support</div>
								<div class="item-sub">Documentation and FAQ</div>
							</div>
							<div class="item-right">&gt;</div>
						</div>
					</div>
				</section>

			</div>

		</div>

	</div>

	<script src="/js/main.js"></script>
	<script src="/js/settings.js"></script>
</body>
</html>
